(kicad_pcb
  (version 20240108)
  (generator "pcbnew")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "W7HAK Telemetry HAT")
    (date "2026-03-30")
    (rev "1.0")
    (comment 1 "Pi Zero W HAT — Resistor Ladder + RC Filters")
    (comment 2 "65mm x 30mm — JST-XH Connectors")
  )
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions yes)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk yes)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  ;; ===================================================================
  ;; BOARD OUTLINE — Pi Zero HAT Form Factor (65mm x 30mm)
  ;; ===================================================================
  ;; Origin at top-left corner of board

  (gr_line (start 0 0) (end 65 0) (stroke (width 0.15) (type default)) (layer "Edge.Cuts"))
  (gr_line (start 65 0) (end 65 30) (stroke (width 0.15) (type default)) (layer "Edge.Cuts"))
  (gr_line (start 65 30) (end 0 30) (stroke (width 0.15) (type default)) (layer "Edge.Cuts"))
  (gr_line (start 0 30) (end 0 0) (stroke (width 0.15) (type default)) (layer "Edge.Cuts"))

  ;; ===================================================================
  ;; MOUNTING HOLES — M2.5, Pi Zero pattern
  ;; ===================================================================
  ;; Pi Zero mounting holes: 58mm x 23mm rectangle
  ;; Offset 3.5mm from left edge, 3.5mm from top edge

  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "mh-1")
    (at 3.5 3.5)
    (property "Reference" "MH1" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "M2.5" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "mh-2")
    (at 61.5 3.5)
    (property "Reference" "MH2" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "M2.5" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "mh-3")
    (at 3.5 26.5)
    (property "Reference" "MH3" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "M2.5" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "mh-4")
    (at 61.5 26.5)
    (property "Reference" "MH4" (at 0 -3 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "M2.5" (at 0 3 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
    (pad "1" thru_hole circle (at 0 0) (size 5.5 5.5) (drill 2.7) (layers "*.Cu" "*.Mask"))
  )

  ;; ===================================================================
  ;; SILKSCREEN ANNOTATIONS
  ;; ===================================================================

  (gr_text "W7HAK Telemetry HAT v1.0" (at 32.5 2 0) (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.2)) (justify center))
  )
  (gr_text "J1: BMS TAPS" (at 8 12 0) (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.12)) (justify center))
  )
  (gr_text "1=Cell4  2=Cell3  3=Cell2  4=Cell1  5=GND" (at 8 13.5 0) (layer "F.SilkS")
    (effects (font (size 0.6 0.6) (thickness 0.1)) (justify center))
  )
  (gr_text "J2: ADS1115" (at 57 12 0) (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.12)) (justify center))
  )
  (gr_text "1=A0  2=A1  3=A2  4=A3  5=VDD  6=GND" (at 57 13.5 0) (layer "F.SilkS")
    (effects (font (size 0.6 0.6) (thickness 0.1)) (justify center))
  )
  (gr_text "GPIO 2x20" (at 32.5 28.5 0) (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.12)) (justify center))
  )
  (gr_text "Pin 1 →" (at 9 27.5 0) (layer "F.SilkS")
    (effects (font (size 0.7 0.7) (thickness 0.1)) (justify center))
  )
  (gr_text "RC FILTER ZONE" (at 32.5 8 0) (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.12)) (justify center))
  )
  (gr_text "25V min caps!" (at 32.5 9.5 0) (layer "F.SilkS")
    (effects (font (size 0.6 0.6) (thickness 0.1)) (justify center))
  )

)
